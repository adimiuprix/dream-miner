# ─── Required ────────────────────────────────────────────────────────────────
# Database connection — must be set in .env (Prisma needs this before DB is accessible)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ─── Moved to AppSetting (manage via /admin/settings) ────────────────────────
# The following were previously stored here but are now managed in the database:
#
#   TON_NETWORK             → hot_wallet_mnemonic setting
#   TON_API_KEY             → ton_api_key setting
#   HOT_WALLET_MNEMONIC     → hot_wallet_mnemonic setting
#   TELEGRAM_NOTIFY_CHAT_ID → telegram_notify_chat_id setting
#   NEXT_PUBLIC_BOT_USERNAME→ bot_username setting
#
# After first deploy, run: npm run db:seed
# Then go to /admin/settings to configure these values.

# ─── Admin Panel Authentication ───────────────────────────────────────────────
# Password untuk login ke /admin
ADMIN_PASSWORD="your_secure_admin_password"
# Secret untuk sign JWT admin — minimal 32 karakter random
ADMIN_JWT_SECRET="your_random_jwt_secret_minimum_32_characters"

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token untuk verifikasi initData dari Telegram Web App (BUG-001 fix).
# Bisa juga diisi via /admin/settings → telegram_bot_token.
# Set ke "dev" untuk bypass verifikasi di local development.
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
