// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String
  lastName     String?
  languageCode String?

  // Mining stats
  tonBalance   Float    @default(0) // Converted TON balance
  // Note: power and hashes are calculated from active contracts, not stored

  // Referral System
  referralCode String   @unique @default(cuid()) // Unique code for sharing
  referredById String?
  referredBy   User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]   @relation("UserReferrals")

  // TON Wallet
  walletAddress String?  // User's TON wallet address for withdrawals

  // Activity Tracking
  lastPingAt   DateTime @default(now()) // To check if user is active/mining
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  contracts    Contract[]
  transactions Transaction[]
  swaps        Swap[]
  userTasks    UserTask[]
}

model Contract {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])
  
  power     Float    // Total power from this contract
  bonus     Float    @default(0) // Bonus power received
  
  accumulatedHashes Float    @default(0)
  lastSyncAt        BigInt   // Unix timestamp in milliseconds

  status    ContractStatus @default(ACTIVE)
  expiresAt BigInt   // Unix timestamp in milliseconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([expiresAt])
}

model Plan {
  id          String   @id @default(cuid())
  name        String   // Display name: "118K", "600K", etc.
  slug        String   @unique // URL-friendly: "plan-118k", "plan-600k"
  
  power       Float    // Base power value: 118000, 600000, etc.
  bonus       Float    @default(0) // Bonus power value
  bonusPercent Float   @default(0) // Bonus percentage for display
  
  price       Float    // Price in TON
  duration    Int      @default(30) // Duration in days (default 30)
  
  description  String?  // Optional description
  finalReturn  String?  // Display text: "1.100 TON", "5.610 TON", etc.
  badge        String?  // Badge text: "+11.8K POWER"
  badgeColor   String?  // Badge color: "#00d4aa"
  
  order       Int      @default(0) // Display order
  isActive    Boolean  @default(true) // Show in shop
  isFree      Boolean  @default(false) // Free plan (price = 0, no wallet needed)
  
  contracts   Contract[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive, order])
  @@index([slug])
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          TransactionType
  amount        Float    // Amount in TON or HASHES
  status        TransactionStatus @default(PENDING)
  
  // TON transaction details
  txHash        String?  // Blockchain transaction hash
  fromAddress   String?  // Sender wallet
  toAddress     String?  // Receiver wallet
  
  // Additional data
  metadata      String?  // JSON string for extra data
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([txHash])
}

model Swap {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  hashesSwapped   Float    // Amount of HASHES swapped
  tonReceived     Float    // Amount of TON received
  exchangeRate    Float    // Exchange rate at the time of swap
  
  // Balance snapshot
  hashesBalanceBefore Float // HASHES balance before swap
  hashesBalanceAfter  Float // HASHES balance after swap (should be 0)
  tonBalanceBefore    Float // TON balance before swap
  tonBalanceAfter     Float // TON balance after swap
  
  status          SwapStatus @default(COMPLETED)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(cuid())
  title       String                          // "Join our Telegram channel"
  description String                          // "Subscribe to @DreamMinerOfficial"
  type        TaskType                        // social | referral | daily | purchase
  reward      Float                           // Power reward amount
  link        String?                         // External URL to open (social tasks)
  isActive    Boolean    @default(true)       // Show to users
  order       Int        @default(0)          // Display order
  
  // For repeatable tasks (e.g. daily)
  isRepeatable  Boolean  @default(false)
  repeatCooldownHours Int @default(24)        // Hours before task can be done again

  completions UserTask[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isActive, order])
  @@index([type])
}

model UserTask {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  powerEarned Float                           // Actual power awarded (snapshot of task.reward)
  completedAt DateTime   @default(now())

  @@index([userId])
  @@index([taskId])
  @@index([completedAt])
}

enum TaskType {
  SOCIAL     // Follow/join social media
  REFERRAL   // Invite friends
  DAILY      // Daily check-in or action
  PURCHASE   // Buy a plan
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionType {
  PURCHASE_POWER
  REFERRAL_BONUS
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SwapStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
